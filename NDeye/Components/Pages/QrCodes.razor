@page "/qr"
@using Microsoft.AspNetCore.Components.Web
@inject NdiFrameService NdiFrameService
<PageTitle>QR Codes</PageTitle>

<div class="container mt-4">

    <h2 class="mb-4">QR Codes</h2>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Snapshot</th>
                    <th>Content</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in NdiFrameService.GetLatestQrContent())
                {
                    <tr>
                        <td class="d-flex justify-content-center">
                            <img src="@item.ThumbnailDataUri"
                                 class="img-thumbnail"
                                 style="height:auto; max-height:256px; max-width:25vw;" />
                        </td>
                        <td>
                            @if (item.Type == QrContentType.Link)
                            {
                                <a href="@item.Content"
                                   class="text-decoration-none fw-semibold">
                                    @item.Content
                                </a>
                            }
                            else
                            {
                                @item.Content
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

